{
  "schemaVersion": 1,
  "id": "bloom_autotune",
  "version": "${version}",
  "name": "Bloom Benchmark",
  "description": "A standardized, fixed-seed Minecraft performance benchmark with average FPS, 1% lows, frame times, and memory measurements.",
  "authors": ["Bloom Client"],
  "contact": {
    "homepage": "https://bloomclient.org",
    "sources": "https://github.com/Parksdotjar/BlimClient",
    "issues": "https://github.com/Parksdotjar/BlimClient/issues"
  },
  "license": "MIT",
  "environment": "client",
  "entrypoints": {
    "client": ["dev.bloomclient.benchmark.BloomBenchmarkClient"]
  },
  "depends": {
    "fabricloader": ">=0.19.3",
    "minecraft": "~26.2",
    "java": ">=25",
    "fabric-api": "*"
  }
}
